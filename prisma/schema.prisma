// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id          String @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  address      String
  phone        String
  status       String      @default("Order Received") // Order Received, Preparing, Out for Delivery
  totalAmount  Float
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id])
  name     String
  quantity Int
  price    Float
}
